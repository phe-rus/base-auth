{
  "name": "base-auth",
  "module": "index.ts",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "www",
    "shared/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=@base-auth/core",
    "test": "turbo run test --filter=@base-auth/core",
    "release": "bun run --filter=\"@base-auth/core\" build && changeset publish"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/bun": "latest",
    "turbo": "2.10.4"
  },
  "dependencies": {
    "@changesets/cli": "2.31.0",
    "prettier": "3.9.4",
    "typescript": "6.0.3"
  },
  "private": true
}
